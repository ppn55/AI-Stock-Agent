# ==========================================
# AI Stock Agent 設定檔範本
# 請將此檔案複製為 .env 並填入您的設定值
# ==========================================

# Google 試算表連結 (請設定為「知道連結的人均可查看」)
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/1xICyi68ZtfgCSm5h5SBeBgz1oXLXID7cZK_v1i1a9h8/edit?gid=0#gid=0

# Zeabur OpenAI API 設定
ZEABUR_API_KEY=your_zeabur_api_key_here
# 請使用 Zeabur AI Hub 的區域端點（東京節點延遲最低，推薦台灣用戶使用）
ZEABUR_API_BASE=https://hnd1.aihub.zeabur.ai/v1
ZEABUR_MODEL=gpt-4o-mini

# 收件人 Email (報告會寄送到這個信箱)
RECIPIENT_EMAIL=your_email@gmail.com

# SMTP 郵件伺服器設定 (以 Gmail 為例)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_username@gmail.com
# Gmail 應用程式密碼 (App Password)，請勿填寫一般登入密碼
SMTP_PASSWORD=your_gmail_app_password_here
